{
    "rewrites": [
        {
            "source": "/analyze/:path*",
            "destination": "https://fakejobai-backend.onrender.com/analyze/:path*"
        },
        {
            "source": "/",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ]
}